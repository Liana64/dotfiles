#!/usr/bin/env bash
# @desc: Manage the ai-memory store with token-frugal output
# Returns slug + description lines, not whole files, so an agent pulls the
# single fact it needs instead of reading the tree into context.
set -euo pipefail

# Packaged into /nix/store, so the store can't be located via $0 — use the
# known repo path (override with AI_MEMORY_DIR). --test builds its own store.
ROOT="${AI_MEMORY_DIR:-$HOME/Projects/Software/ai-memory}"
if [ "${1:-}" != --test ]; then
  [ -d "$ROOT/global" ] || { echo "ai-memory: no store at $ROOT" >&2; exit 1; }
  cd "$ROOT"
fi

# field <file> <key> — print a frontmatter scalar (between the --- fences).
# Keys are literals from this script, never file content.
field() {
  awk -v k="$2" '
    /^---[[:space:]]*$/ { f++; next }
    f==1 && index($0, k":")==1 { sub("^"k":[[:space:]]*",""); print; exit }
  ' "$1"
}

# mtype <file> — metadata type (indented under metadata:, so not field()).
mtype() {
  awk '
    /^---[[:space:]]*$/ { f++; next }
    f==1 && /^[[:space:]]*type:/ { sub(/^[[:space:]]*type:[[:space:]]*/, ""); print; exit }
  ' "$1"
}

# memfiles — every memory file, excluding index/task lists.
memfiles() {
  find global projects -type f -name '*.md' \
    ! -name MEMORY.md ! -name TODO.md ! -name README.md | sort
}

scope() { # global/foo.md -> global ; projects/x/foo.md -> x (no newline)
  case "$1" in
    global/*) printf 'global' ;;
    projects/*) printf '%s' "$(basename "$(dirname "$1")")" ;;
  esac
}

cmd_list() { # list [scope] — one terse line per memory
  local want="${1:-}" f s
  while read -r f; do
    s="$(scope "$f")"
    if [ -z "$want" ] || [ "$s" = "$want" ]; then
      printf '[%s] %s — %s\n' "$s" "$(field "$f" name)" "$(field "$f" description)"
    fi
  done < <(memfiles)
}

cmd_search() { # search <term> — files whose name/desc/body match; slug + desc only
  [ $# -ge 1 ] || { echo "usage: ai-memory search <term>" >&2; exit 2; }
  local f
  while read -r f; do
    if grep -qiF -- "$1" "$f"; then
      printf '[%s] %s — %s\n' "$(scope "$f")" "$(field "$f" name)" "$(field "$f" description)"
    fi
  done < <(memfiles)
}

cmd_show() { # show <slug> — print one memory (resolves by filename or name field)
  [ $# -ge 1 ] || { echo "usage: ai-memory show <slug>" >&2; exit 2; }
  local q="${1%.md}" f
  while read -r f; do
    if [ "$(basename "$f" .md)" = "$q" ] || [ "$(field "$f" name)" = "$q" ]; then
      cat "$f"; return 0
    fi
  done < <(memfiles)
  echo "no memory: $q" >&2; return 1
}

cmd_check() { # check — index<->file drift, missing frontmatter, links, budgets
  local rc=0 idx dir f ref names l n
  for idx in global/MEMORY.md projects/*/MEMORY.md; do
    dir="$(dirname "$idx")"
    for f in "$dir"/*.md; do
      case "$(basename "$f")" in MEMORY.md|TODO.md|README.md) continue ;; esac
      if ! grep -qF "($(basename "$f"))" "$idx"; then
        echo "orphan: $f not in $idx"; rc=1
      fi
    done
    while read -r ref; do
      [ -e "$dir/$ref" ] || { echo "dangling: $idx -> $ref missing"; rc=1; }
    done < <(grep -oE '\(([a-z0-9_-]+\.md)\)' "$idx" | tr -d '()')
  done
  while read -r f; do
    for k in name description; do
      [ -n "$(field "$f" "$k")" ] || { echo "nofield: $f missing '$k'"; rc=1; }
    done
  done < <(memfiles)
  # [[links]] resolve against name: fields (files are snake_case, names kebab).
  # Informational only: a dangling link may be a legitimate forward-link.
  names="$(while read -r f; do field "$f" name; done < <(memfiles))"
  while read -r f; do
    while read -r l; do
      grep -qxF -- "$l" <<<"$names" || echo "link: $f -> [[$l]] unresolved"
    done < <(grep -oE '\[\[[A-Za-z0-9_-]+\]\]' "$f" | tr -d '[]' | sort -u)
  done < <(memfiles)
  # budget: informational — always-loaded index weight and journal cap
  for idx in global/MEMORY.md projects/*/MEMORY.md; do
    n=$(wc -l <"$idx")
    [ "$n" -gt 25 ] && echo "budget: $idx $n lines (soft cap 25)"
  done
  if [ -f JOURNAL.md ]; then
    n=$(awk '/^---[[:space:]]*$/ { f++; next } f >= 2 && NF' JOURNAL.md | wc -l)
    [ "$n" -gt 30 ] && echo "budget: JOURNAL.md $n body lines (cap 30)"
  fi
  return $rc
}

cmd_stats() { # stats — memory count per scope + index weight (loaded every session)
  local f idx
  while read -r f; do printf '%s\n' "$(scope "$f")"; done < <(memfiles) | sort | uniq -c
  for idx in global/MEMORY.md projects/*/MEMORY.md; do
    printf 'index %s: %d lines, %d bytes\n' "$idx" "$(wc -l <"$idx")" "$(wc -c <"$idx")"
  done
}

cmd_stale() { # stale [days] — prune candidates: no commit or confirm inside window
  local days="${1:-90}" now f d w de slug c
  now=$(date +%s)
  while read -r f; do
    d="$(git log -1 --format=%as -- "$f")" # author date: survives sync's rebase
    [ -n "$d" ] || continue                # uncommitted: not a candidate
    slug="$(field "$f" name)"
    if [ -f confirmations.log ]; then
      # slug = line after the first space (name: fields may contain spaces)
      c="$(awk -v s="$slug" '{ r = $0; sub(/^[^ ]+ /, "", r) } r == s { d = $1 } END { if (d) print d }' confirmations.log)"
      if [ -n "$c" ] && [[ "$c" > "$d" ]]; then d="$c"; fi
    fi
    w="$days"
    # stable references rot slowly; don't churn them through judgment
    if [ "$(mtype "$f")" = "reference" ] && [ "$days" -lt 365 ]; then w=365; fi
    de="$(date -d "$d" +%s)"
    if [ "$de" -lt $((now - w * 86400)) ]; then
      printf '%s\t[%s] %s — %s (%s)\n' "$de" "$(scope "$f")" "$slug" "$(field "$f" description)" "$d"
    fi
  done < <(memfiles) | sort -n | cut -f2-
  return 0
}

cmd_trend() { # trend [months] — monthly index weight (bytes) from git history
  local months="${1:-6}" idx rev d mon first out
  local -A last
  first="$(date -d "$(date +%Y-%m-15) -$((months - 1)) months" +%Y-%m)"
  for idx in global/MEMORY.md projects/*/MEMORY.md; do
    last=()
    while read -r rev d; do
      mon="${d%-*}"
      if ! [[ "$mon" < "$first" ]]; then last[$mon]="$rev"; fi # last commit per month
    done < <(git log --format='%H %as' --reverse -- "$idx")
    out=""
    while read -r mon; do
      [ -n "$mon" ] || continue
      out+="$mon $(git cat-file -s "${last[$mon]}:$idx")B, "
    done < <(printf '%s\n' "${!last[@]}" | sort)
    [ -n "$out" ] && printf '%s: %s\n' "$idx" "${out%, }"
  done
  return 0
}

cmd_debt() { # debt [days] — one whisper line when the dream loop is stale
  local days="${1:-21}" d m=0 age
  d="$(git log -1 --grep='^dream:' --format=%as 2>/dev/null || true)"
  # '→ proposed:' with colon — the format-doc line says '→ proposed|adopted…'
  if [ -f JOURNAL.md ]; then m="$(grep -c '→ proposed:' JOURNAL.md || true)"; fi
  if [ -z "$d" ]; then
    echo "no /dream yet; $m proposals open"
    return 0
  fi
  age=$((($(date +%s) - $(date -d "$d" +%s)) / 86400))
  if [ "$age" -gt "$days" ]; then
    echo "no /dream in ${age}d; $m proposals open"
  fi
  return 0
}

cmd_confirm() { # confirm <slug> — still-true judgment, logged below the context line
  [ $# -ge 1 ] || { echo "usage: ai-memory confirm <slug>" >&2; exit 2; }
  local q="${1%.md}" f found=""
  while read -r f; do
    if [ "$(basename "$f" .md)" = "$q" ] || [ "$(field "$f" name)" = "$q" ]; then
      found="$(field "$f" name)"; break
    fi
  done < <(memfiles)
  [ -n "$found" ] || { echo "no memory: $q" >&2; return 1; }
  # rewrite: drop expired (>365d) + prior lines for this slug, append today's
  {
    if [ -f confirmations.log ]; then
      awk -v cut="$(date -d '365 days ago' +%F)" -v s="$found" \
        '{ r = $0; sub(/^[^ ]+ /, "", r) } $1 >= cut && r != s' confirmations.log
    fi
    printf '%s %s\n' "$(date +%F)" "$found"
  } >confirmations.log.tmp && mv confirmations.log.tmp confirmations.log
  echo "confirmed $found"
}

cmd_pull() { # pull — rebase local onto remote (best-effort, bounded)
  timeout 30 git pull --rebase --autostash -q 2>/dev/null &&
    echo "pulled" || echo "pull skipped (offline?)"
}

cmd_sync() { # sync [msg] — commit, rebase onto remote, push (never forced)
  git add -A
  git diff --cached --quiet || git commit -q -m "${1:-ai-memory: update memories}"
  if ! timeout 30 git pull --rebase --autostash -q 2>/dev/null; then
    # a conflicted rebase must not be left wedged (offline pull also lands here)
    if [ -d .git/rebase-merge ] || [ -d .git/rebase-apply ]; then
      git rebase --abort
      echo "diverged (manual merge needed)"
      return 1
    fi
  fi
  if [ -z "$(git log --branches --not --remotes 2>/dev/null)" ]; then
    echo "in sync"
  elif timeout 30 git push -q 2>/dev/null; then
    echo "pushed"
  else
    echo "committed (push failed)"
  fi
}

cmd_test() { # --test — exercise the store-facing verbs on a fixture store
  local tmp fails=0 out
  tmp=$(mktemp -d)
  # shellcheck disable=SC2064  # value baked in: the trap fires at script exit, after this local is gone
  # shellcheck disable=SC2064
  trap "rm -rf '$tmp'" EXIT
  export GIT_AUTHOR_NAME=t GIT_AUTHOR_EMAIL=t@t \
    GIT_COMMITTER_NAME=t GIT_COMMITTER_EMAIL=t@t
  ok() { printf 'pass  %s\n' "$1"; }
  bad() { printf 'FAIL  %s\n' "$1"; fails=$((fails + 1)); }
  yes_() { if "${@:2}" >/dev/null 2>&1; then ok "$1"; else bad "$1"; fi; }
  no_() { if "${@:2}" >/dev/null 2>&1; then bad "$1"; else ok "$1"; fi; }
  mem() { # <path> <name> <type> [body]
    printf -- '---\nname: %s\ndescription: desc of %s\nmetadata:\n  type: %s\n---\n\n%s\n' \
      "$2" "$2" "$3" "${4:-body}" >"$1"
  }

  git init -q "$tmp"
  mkdir -p "$tmp/global" "$tmp/projects/p"
  cd "$tmp"
  mem global/old_fact.md old-fact feedback 'links [[fresh-fact]] and [[nowhere]]'
  mem global/ref_doc.md ref-doc reference
  mem global/fresh_fact.md fresh-fact feedback
  printf -- '- [O](old_fact.md)\n- [R](ref_doc.md)\n- [F](fresh_fact.md)\n- [G](gone.md)\n' >global/MEMORY.md
  mem projects/p/orphan.md orphan project
  printf 'Project dir: /x\n' >projects/p/MEMORY.md
  git add -A
  GIT_AUTHOR_DATE="$(date -d '-200 days' +%F)T12:00:00" git commit -qm seed
  mem global/fresh_fact.md fresh-fact feedback refreshed
  git add -A && git commit -qm freshen

  yes_ 'list covers both scopes' grep -q '\[p\] orphan' <<<"$(cmd_list)"
  yes_ 'show resolves by name' grep -q 'desc of old-fact' <<<"$(cmd_show old-fact)"
  yes_ 'show resolves by filename' grep -q 'desc of old-fact' <<<"$(cmd_show old_fact)"
  no_ 'show fails on missing' cmd_show no-such
  out=$(cmd_check || true)
  yes_ 'check flags orphan' grep -q 'orphan: projects/p/orphan.md' <<<"$out"
  yes_ 'check flags dangling index ref' grep -q 'dangling: global/MEMORY.md -> gone.md' <<<"$out"
  yes_ 'check flags unresolved link' grep -q '\[\[nowhere\]\] unresolved' <<<"$out"
  no_ 'check resolves live link' grep -q 'fresh-fact\]\] unresolved' <<<"$out"
  yes_ 'stale lists old memory' grep -q 'old-fact' <<<"$(cmd_stale 90)"
  no_ 'stale spares reference under 365d' grep -q 'ref-doc' <<<"$(cmd_stale 90)"
  no_ 'stale spares fresh commit' grep -q 'fresh-fact' <<<"$(cmd_stale 90)"
  no_ 'stale respects window' grep -q . <<<"$(cmd_stale 400)"
  yes_ 'confirm accepts known slug' cmd_confirm old-fact
  yes_ 'confirm logged' grep -q 'old-fact' confirmations.log
  no_ 'stale honors confirmation' grep -q 'old-fact' <<<"$(cmd_stale 90)"
  no_ 'confirm rejects missing' cmd_confirm no-such
  mem global/uncommitted.md uncommitted feedback
  no_ 'stale skips uncommitted file' grep -q 'uncommitted' <<<"$(cmd_stale 1)"
  rm global/uncommitted.md
  yes_ 'debt before any dream' grep -q 'no /dream yet' <<<"$(cmd_debt)"
  GIT_AUTHOR_DATE="$(date -d '-30 days' +%F)T12:00:00" git commit -q --allow-empty -m 'dream: t'
  yes_ 'debt whispers past window' grep -q 'no /dream in' <<<"$(cmd_debt 21)"
  no_ 'debt silent inside window' grep -q . <<<"$(cmd_debt 60)"
  yes_ 'stats reports index weight' grep -q 'index global/MEMORY.md' <<<"$(cmd_stats)"
  yes_ 'trend emits monthly bytes' grep -q 'global/MEMORY.md: ' <<<"$(cmd_trend 12)"
  printf '%s\n' x x x x x x x x x x x x x x x x x x x x x x x x x x >projects/p/MEMORY.md
  yes_ 'check flags index budget' grep -q 'budget: projects/p/MEMORY.md' <<<"$(cmd_check || true)"

  [ "$fails" -eq 0 ]
}

case "${1:-}" in
  pull)   shift; cmd_pull "$@" ;;
  list)   shift; cmd_list "$@" ;;
  search) shift; cmd_search "$@" ;;
  show)   shift; cmd_show "$@" ;;
  check)  shift; cmd_check "$@" ;;
  stats)  shift; cmd_stats "$@" ;;
  stale)  shift; cmd_stale "$@" ;;
  trend)  shift; cmd_trend "$@" ;;
  debt)   shift; cmd_debt "$@" ;;
  confirm) shift; cmd_confirm "$@" ;;
  --test) shift; cmd_test "$@" ;;
  sync)   shift; cmd_sync "$@" ;;
  *) cat >&2 <<'EOF'
ai-memory — token-frugal ai-memory management
  ai-memory list [scope]    one line per memory (optionally one scope)
  ai-memory search <term>   slug + desc for memories matching term
  ai-memory show <slug>     print one memory file
  ai-memory check           report index/file drift, missing frontmatter, dangling links
  ai-memory stats           memory count per scope + index weight
  ai-memory stale [days]    prune candidates: no commit/confirm in window (default 90)
  ai-memory trend [months]  monthly index weight from git history (default 6)
  ai-memory debt [days]     whisper when no dream in window (default 21); else silent
  ai-memory confirm <slug>  log a still-true judgment (resets staleness clock)
  ai-memory pull            rebase onto remote (best-effort)
  ai-memory sync [msg]      commit, rebase, push (best-effort)
EOF
    exit 2 ;;
esac
