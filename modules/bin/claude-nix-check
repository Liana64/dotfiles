#!/bin/sh
# @desc: PostToolUse hook — format edited .nix in place (alejandra), then lint it (statix, deadnix)
# Exit 2 feeds findings back for an immediate fix.

file=$(jq -r '.tool_input.file_path // empty')
case "$file" in
  *.nix) ;;
  *) exit 0 ;;
esac
[ -f "$file" ] || exit 0

if ! err=$(alejandra -q "$file" 2>&1); then
  printf 'alejandra could not format %s:\n%s\n' "$file" "$err" >&2
  exit 2
fi

# statix reads statix.toml from the cwd; judged by output, not exit codes
lint=$({
  statix check -o errfmt "$file"
  deadnix "$file"
} 2>&1)
[ -z "$lint" ] && exit 0
printf '%s\n' "$lint" >&2
exit 2
