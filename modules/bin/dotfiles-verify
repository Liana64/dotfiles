#!/bin/sh
# @desc: Quiet flake-eval check for the four configs, evaluated concurrently
# Prints "all configs ✓", or per-target results with the last ~20 lines of
# the trace on failure. Pass a flake ref to override '.'.

flake=${1:-.}

# Untracked .nix files are invisible to flake eval — a green result would lie.
if git -C "$flake" rev-parse --git-dir >/dev/null 2>&1; then
  untracked=$(git -C "$flake" ls-files --others --exclude-standard -- '*.nix')
  [ -n "$untracked" ] &&
    printf 'untracked .nix (git add before trusting results):\n%s\n' "$untracked"
fi

tmp=$(mktemp -d) || exit 1
trap 'rm -rf "$tmp"' EXIT

# Each job writes its formatted result to an indexed file; cat after wait
# restores declaration order regardless of completion order.
i=0
while IFS='=' read -r label attr; do
  i=$((i + 1))
  {
    if err=$(nix eval "$flake#$attr" 2>&1 >/dev/null); then
      printf '%s ✓\n' "$label"
    else
      touch "$tmp/failed"
      printf '%s ✗\n%s\n' "$label" "$(printf '%s\n' "$err" | tail -n 20)"
    fi
  } >"$tmp/$(printf '%02d' "$i").out" &
done <<EOF
framework=nixosConfigurations.framework.config.system.build.toplevel.drvPath
portable=nixosConfigurations.portable.config.system.build.toplevel.drvPath
liana@framework=homeConfigurations."liana@framework".activationPackage.drvPath
liana@portable=homeConfigurations."liana@portable".activationPackage.drvPath
EOF
wait

if [ -e "$tmp/failed" ]; then
  cat "$tmp"/*.out
  exit 1
fi
printf 'all configs ✓\n'

# success stamp: .nix dirty-state baseline, read by the claude-stop-verify hook
root=$(git -C "$flake" rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -f "$root/modules/flake/hosts.nix" ] || exit 0
git -C "$root" status --porcelain -uall -- '*.nix' \
  >"${XDG_RUNTIME_DIR:-/tmp}/dotfiles-verify.$(printf '%s' "$root" | cksum | tr -cd '[:digit:]')"
