#!/bin/sh
# Waybar Taskwarrior indicator: active task, else due/overdue counts. Hidden via the toggle flag.
[ -e "$XDG_RUNTIME_DIR/waybar-task-hidden" ] && exit 0
active=$(task rc.context=none +ACTIVE export 2>/dev/null | jq -c 'sort_by(.modified) | last // empty')
if [ -n "$active" ]; then
  printf '%s' "$active" | jq -c '{
    text: ("▶ " + .description),
    class: "active",
    tooltip: ((.upstream // "") | if . == "" then "active" else "Upstream: " + . end)
  }'
  exit 0
fi
# Due/overdue counts. Classify by CALENDAR day in local time (not a rolling 24h window).
task rc.context=none status:pending due.any: export 2>/dev/null | jq -c '
  ((now | localtime | mktime) - now) as $off
  | ((now + $off) / 86400 | floor) as $today
  | map(. + {days: ((((.due | strptime("%Y%m%dT%H%M%SZ") | mktime) + $off) / 86400 | floor) - $today)})
  | map(select(.days <= 0))
  | select(length > 0)
  | (map(select(.days < 0)) | length) as $over
  | (length - $over) as $due
  | {
      text: ([(if $due > 0 then "\($due) due" else empty end),
              (if $over > 0 then "\($over) overdue" else empty end)] | join(" · ")),
      class: (if $over > 0 then "overdue" else "due-today" end),
      tooltip: (sort_by(.due) | map(.description) | join("\n"))
    }'
