# Body of the wg-autoconnect service. wireguard.nix prepends the shebang,
# PATH (openresolv first) and $WG_CONFIG.
# shellcheck shell=bash

WG_INTERFACE="wg0"
TRUSTED_NETWORKS="Milberry"

is_up()       { ip link show "$WG_INTERFACE" &>/dev/null; }
is_ethernet() { nmcli -t -f type,state dev | grep -q '^ethernet:connected'; }
is_online()   { [[ "$(nmcli -t -f CONNECTIVITY general)" == full ]]; }

is_trusted() {
  local ssid current_ssid
  current_ssid=$(nmcli -t -f active,ssid dev wifi | grep '^yes:' | cut -d: -f2-)
  [[ -z "$current_ssid" ]] && return 1
  while IFS= read -r ssid; do
    [[ "$ssid" =~ ^#.*$ || -z "$ssid" ]] && continue
    ssid=$(echo "$ssid" | xargs)
    [[ "$current_ssid" == "$ssid" ]] && return 0
  done <<< "$TRUSTED_NETWORKS"
  return 1
}

evaluate() {
  if is_ethernet || is_trusted; then
    echo safe > /run/wg-network-state
    is_up && wg-quick down "$WG_CONFIG"
  elif is_online; then
    echo untrusted > /run/wg-network-state
    is_up || wg-quick up "$WG_CONFIG"
  else
    echo offline > /run/wg-network-state
    is_up && wg-quick down "$WG_CONFIG"
  fi
}

evaluate
nmcli monitor | while read -r _; do evaluate; done
