#!/bin/sh
# Claude Code PreToolUse hook: decline access to secrets files and commands.
# Run `claude-secrets-guard --test` to execute the fixture.
set -f

# <name> <ERE>. Word-boundary anchored so JSON keys, identifiers, and prose
# containing the same substrings do not match.
bash_rules='
kubectl-secret-access  \bkubectl\b.*\b(get|describe|edit)\b[[:space:]]+secrets?\b
kubectl-view-secret    \bkubectl\b.*\bview-secret\b
vault-read             \bvault\b[[:space:]]+(read|kv[[:space:]]+(get|read))\b
aws-secret-read        \baws\b[[:space:]]+secretsmanager[[:space:]]+get-secret-value\b
aws-ssm-read           \baws\b[[:space:]]+ssm[[:space:]]+get-parameter\b
gcloud-secret-read     \bgcloud\b[[:space:]]+secrets[[:space:]]+versions[[:space:]]+access\b
1password-read         \bop\b[[:space:]]+(read|item[[:space:]]+get)\b
bitwarden-read         \bbw\b[[:space:]]+get\b
pass-show              \bpass\b[[:space:]]+show\b
'

file_globs='*.pem *.key *.p12 *.pfx *.ppk *.p8 *.jks *.keystore
id_rsa id_ed25519 id_ecdsa id_dsa
*.env .env* *.tfvars *.tfstate* *.ovpn
*.gpg *.asc *.kdbx *.age *.enc
credentials *kubeconfig .git-credentials .netrc .pgpass .npmrc .htpasswd .vault-token'

dirs='.ssh .gnupg .aws .kube .password-store'

deny() {
  jq -n --arg r "$1" \
    '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$r}}'
  exit 0
}

# Turn a file glob into an ERE. A leading/trailing '*' means "any filename
# chars on that side", so the opposite side anchors on a path boundary while
# the wildcard side may carry a prefix/suffix (e.g. `terraform.tfvars` still
# matches `*.tfvars`). Globs without a '*' anchor on both sides so they do not
# match inside identifiers like `dotenv-linter`. Returns 1 for cores < 4 chars.
glob_to_re() {
  pat=$1 lead= trail=
  case "$pat" in \**) lead=1; pat=${pat#\*} ;; esac
  case "$pat" in *\*) trail=1; pat=${pat%\*} ;; esac
  [ ${#pat} -lt 4 ] && return 1
  esc=$(printf '%s' "$pat" | sed 's/[^[:alnum:]_-]/\\&/g')
  b='[[:space:]=:"'\''/]'; fn='[[:alnum:]._-]*'
  [ -n "$lead" ]  && L="(^|$b)$fn"   || L="(^|$b)"
  [ -n "$trail" ] && R="$fn(\$|$b)"  || R="(\$|$b)"
  printf '%s%s%s' "$L" "$esc" "$R"
}

scan_bash() {
  cmd=$1
  hit=$(printf '%s\n' "$bash_rules" | while read -r name re; do
    [ -z "$name" ] && continue
    printf '%s' "$cmd" | grep -Eq -- "$re" && { printf '%s' "$name"; break; }
  done)
  [ -n "$hit" ] && deny "secret-reading command declined: rule $hit"

  for pat in $file_globs; do
    re=$(glob_to_re "$pat") || continue
    if printf '%s' "$cmd" | grep -Eq -- "$re"; then
      deny "secrets-type file declined: command references $pat"
    fi
  done

  for d in $dirs; do
    case "$cmd" in
      *"$d"/*) deny "secrets directory declined: command references $d" ;;
    esac
  done
}

scan_file() {
  path=$1
  base=${path##*/}
  for pat in $file_globs; do
    case "$base" in
      $pat) deny "secrets-type file declined: $base ($pat)" ;;
    esac
  done
  for d in $dirs; do
    case "$path" in
      *"$d/"*) deny "secrets directory declined: $d" ;;
    esac
  done
}

run_tests() {
  fail=0
  bash_in() { jq -nc --arg c "$1" '{tool_name:"Bash",tool_input:{command:$c}}'; }
  read_in() { jq -nc --arg p "$1" '{tool_name:"Read",tool_input:{file_path:$p}}'; }
  t() {
    name=$1 expect=$2 input=$3
    out=$(printf '%s' "$input" | "$0")
    if [ -z "$out" ]; then
      got=allow
    else
      got=$(printf '%s' "$out" | jq -r '.hookSpecificOutput.permissionDecision // "allow"')
    fi
    if [ "$got" = "$expect" ]; then
      printf 'PASS  %s\n' "$name"
    else
      printf 'FAIL  %s (want=%s got=%s)\n' "$name" "$expect" "$got"
      fail=1
    fi
  }

  t kubectl-patch-json-readonly allow "$(bash_in 'kubectl patch hr glance --type=json -p=[{"op":"add","path":"/x","value":{"readOnly":true}}]')"
  t prose-option-read   allow "$(bash_in 'echo the option to read')"
  t subway-getinfo      allow "$(bash_in 'echo subway-getinfo')"
  t kubectl-get-pods    allow "$(bash_in 'kubectl get pods')"
  t dotenv-linter       allow "$(bash_in 'echo dotenv-linter is fine')"

  t 1password-read      deny "$(bash_in 'op read op://vault/item/field')"
  t 1password-item-get  deny "$(bash_in 'op item get foo')"
  t kubectl-get-secret  deny "$(bash_in 'kubectl get secret foo')"
  t vault-kv-get        deny "$(bash_in 'vault kv get secret/foo')"
  t aws-secret          deny "$(bash_in 'aws secretsmanager get-secret-value --secret-id foo')"
  t bw-get              deny "$(bash_in 'bw get password foo')"
  t pem-read            deny "$(read_in '/tmp/server.pem')"
  t ssh-dir             deny "$(read_in '/home/x/.ssh/id_rsa')"
  t cat-tfvars-prefix   deny "$(bash_in 'cat tofu/lab/terraform.tfvars')"
  t cat-env-prefix      deny "$(bash_in 'cat /srv/app/production.env')"
  t cat-pem-prefix      deny "$(bash_in 'cat /etc/ssl/server.pem')"
  t cat-kubeconfig      deny "$(bash_in 'cat ~/prod.kubeconfig')"
  t echo-environment-ok allow "$(bash_in 'echo my.environment is set')"

  exit $fail
}

[ "$1" = "--test" ] && run_tests

input=$(cat)
tool=$(printf '%s' "$input" | jq -r '.tool_name // empty')

case "$tool" in
  Read|Edit|MultiEdit|Write|NotebookEdit)
    path=$(printf '%s' "$input" | jq -r '.tool_input.file_path // .tool_input.notebook_path // empty')
    [ -n "$path" ] && scan_file "$path" ;;
  Bash)
    cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // empty')
    [ -n "$cmd" ] && scan_bash "$cmd" ;;
esac

exit 0
