#!/bin/sh
# Claude Code statusLine: context window and plan rate-limit usage.

jq -r '
  (.model.display_name // "Claude") as $m
  | ((.context_window.used_percentage // 0) | round) as $ctx
  | "\($m) · ctx \($ctx)%"
    + (if .rate_limits.five_hour.used_percentage != null
       then " · 5h \(.rate_limits.five_hour.used_percentage | round)%"
            + (if .rate_limits.five_hour.resets_at != null
               then " (\(.rate_limits.five_hour.resets_at | localtime | strftime("%-I:%M %p")))"
               else "" end)
       else "" end)
    + (if .rate_limits.seven_day.used_percentage != null
       then " · 7d \(.rate_limits.seven_day.used_percentage | round)%"
            + (if .rate_limits.seven_day.resets_at != null
               then " (\(.rate_limits.seven_day.resets_at | localtime | strftime("%b %-d")))"
               else "" end)
       else "" end)
'
